{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.knowledge-graph.dev/schemas/chat-events.schema.json",
  "title": "Chat SSE Event",
  "description": "Discriminated-union schema for the SSE event stream emitted by POST /chats/{chat_id}/messages. The wire-format frame is `event: <type>\\nid: <monotonic-int>\\ndata: <json>`. This schema models the deserialised event object that a client library produces from each frame: the SSE `event` line becomes `event`, the SSE `id` becomes `id`, and the JSON in `data` is event-specific.\n\nOrdering contract per message:\n  1. exactly one `stream_start` first\n  2. `retrieval_started` -> zero or more `tool_call`/`tool_result` pairs (Tier 4) -> `retrieval_completed`\n  3. interleaved `citation` events (each chunk_id referenced in tokens MUST appear in a prior or concurrent `citation` event - enforces REQ-1.5.4)\n  4. one or more `token` events\n  5. exactly one `usage` event\n  6. exactly one terminal: either `message_completed` or `error`\n  `heartbeat` may appear at any time (15s keep-alive).\n\nThe `id` field is monotonic per message, enabling `Last-Event-ID` resume (Tier 2+).",

  "oneOf": [
    { "$ref": "#/$defs/StreamStart" },
    { "$ref": "#/$defs/RetrievalStarted" },
    { "$ref": "#/$defs/RetrievalCompleted" },
    { "$ref": "#/$defs/CitationEvent" },
    { "$ref": "#/$defs/Token" },
    { "$ref": "#/$defs/ToolCall" },
    { "$ref": "#/$defs/ToolResult" },
    { "$ref": "#/$defs/Usage" },
    { "$ref": "#/$defs/MessageCompleted" },
    { "$ref": "#/$defs/ErrorEvent" },
    { "$ref": "#/$defs/Heartbeat" }
  ],

  "$defs": {

    "Uuid": {
      "type": "string",
      "format": "uuid"
    },

    "EventId": {
      "type": "integer",
      "minimum": 0,
      "description": "SSE frame id. Monotonic per message; enables `Last-Event-ID` resume."
    },

    "EventBase": {
      "type": "object",
      "required": ["event", "id"],
      "properties": {
        "event": { "type": "string" },
        "id": { "$ref": "#/$defs/EventId" }
      }
    },

    "RetrievalMode": {
      "type": "string",
      "enum": ["vector", "hybrid", "graph_only"]
    },

    "FinishReason": {
      "type": "string",
      "enum": ["stop", "length", "content_filter", "error"]
    },

    "Tool": {
      "type": "string",
      "description": "Designed in Tier 1; first emitted in Tier 4 once hybrid retrieval and SPARQL templates land.",
      "enum": ["kg_traverse", "sparql_template", "web_search"]
    },

    "CitationData": {
      "type": "object",
      "description": "Mirrors `components.schemas.Citation` in openapi.yaml. Duplicated here so the SSE event schema is self-contained; keep in sync.",
      "required": [
        "id",
        "chunk_id",
        "document_id",
        "document_title",
        "document_version",
        "excerpt"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/Uuid" },
        "chunk_id": { "$ref": "#/$defs/Uuid" },
        "document_id": { "$ref": "#/$defs/Uuid" },
        "document_title": { "type": "string" },
        "document_version": { "type": "string" },
        "page_number": { "type": ["integer", "null"] },
        "excerpt": { "type": "string" },
        "score": { "type": "number" },
        "unavailable": { "type": "boolean", "default": false },
        "unavailable_reason": { "type": ["string", "null"] }
      }
    },

    "Problem": {
      "type": "object",
      "description": "RFC 9457 problem detail. Mirrors `components.schemas.Problem` in openapi.yaml.",
      "required": ["type", "title", "status", "request_id", "code"],
      "properties": {
        "type": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "status": { "type": "integer" },
        "detail": { "type": "string" },
        "instance": { "type": "string", "format": "uri" },
        "request_id": { "$ref": "#/$defs/Uuid" },
        "code": { "type": "string" },
        "retry_after_seconds": { "type": "integer" }
      }
    },

    "Message": {
      "type": "object",
      "description": "Mirrors `components.schemas.Message` in openapi.yaml. The full payload sent in `message_completed.data.full_message`.",
      "required": ["id", "chat_id", "role", "content", "citations", "created_at"],
      "properties": {
        "id": { "$ref": "#/$defs/Uuid" },
        "chat_id": { "$ref": "#/$defs/Uuid" },
        "role": { "type": "string", "enum": ["user", "assistant", "system"] },
        "content": { "type": "string" },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/CitationData" }
        },
        "model": { "type": "string" },
        "usage": {
          "type": "object",
          "properties": {
            "input_tokens": { "type": "integer" },
            "output_tokens": { "type": "integer" },
            "total_tokens": { "type": "integer" },
            "cost_usd_micros": { "type": "integer" }
          }
        },
        "finish_reason": { "$ref": "#/$defs/FinishReason" },
        "error": { "anyOf": [{ "$ref": "#/$defs/Problem" }, { "type": "null" }] },
        "as_of_date": { "type": ["string", "null"], "format": "date" },
        "retrieval_mode": { "anyOf": [{ "$ref": "#/$defs/RetrievalMode" }, { "type": "null" }] },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },

    "StreamStart": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "stream_start" },
            "data": {
              "type": "object",
              "required": ["message_id", "chat_id", "started_at"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "chat_id": { "$ref": "#/$defs/Uuid" },
                "model": { "type": "string" },
                "started_at": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      ]
    },

    "RetrievalStarted": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "retrieval_started" },
            "data": {
              "type": "object",
              "required": ["message_id", "top_k"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "mode": { "anyOf": [{ "$ref": "#/$defs/RetrievalMode" }, { "type": "null" }] },
                "top_k": { "type": "integer", "minimum": 1 },
                "as_of_date": { "type": ["string", "null"], "format": "date" }
              }
            }
          }
        }
      ]
    },

    "RetrievalCompleted": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "retrieval_completed" },
            "data": {
              "type": "object",
              "required": ["message_id", "chunk_ids", "elapsed_ms"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "chunk_ids": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/Uuid" }
                },
                "triple_ids": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/Uuid" },
                  "description": "Populated from Tier 4 (hybrid retrieval)."
                },
                "elapsed_ms": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      ]
    },

    "CitationEvent": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "citation" },
            "data": {
              "type": "object",
              "required": ["message_id", "citation"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "citation": { "$ref": "#/$defs/CitationData" }
              }
            }
          }
        }
      ]
    },

    "Token": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "token" },
            "data": {
              "type": "object",
              "required": ["message_id", "delta", "index"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "delta": { "type": "string" },
                "index": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      ]
    },

    "ToolCall": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "tool_call" },
            "data": {
              "type": "object",
              "required": ["message_id", "tool", "call_id", "input"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "tool": { "$ref": "#/$defs/Tool" },
                "call_id": { "$ref": "#/$defs/Uuid" },
                "input": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      ]
    },

    "ToolResult": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "tool_result" },
            "data": {
              "type": "object",
              "required": ["message_id", "call_id", "elapsed_ms"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "call_id": { "$ref": "#/$defs/Uuid" },
                "output_summary": { "type": "object", "additionalProperties": true },
                "elapsed_ms": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      ]
    },

    "Usage": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "usage" },
            "data": {
              "type": "object",
              "required": ["message_id", "input_tokens", "output_tokens", "total_tokens"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "input_tokens": { "type": "integer", "minimum": 0 },
                "output_tokens": { "type": "integer", "minimum": 0 },
                "total_tokens": { "type": "integer", "minimum": 0 },
                "cost_usd_micros": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Populated from Tier 2 onward."
                }
              }
            }
          }
        }
      ]
    },

    "MessageCompleted": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "message_completed" },
            "data": {
              "type": "object",
              "required": ["message_id", "finish_reason", "full_message"],
              "properties": {
                "message_id": { "$ref": "#/$defs/Uuid" },
                "finish_reason": { "$ref": "#/$defs/FinishReason" },
                "full_message": { "$ref": "#/$defs/Message" }
              }
            }
          }
        }
      ]
    },

    "ErrorEvent": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "error" },
            "data": {
              "type": "object",
              "required": ["problem"],
              "properties": {
                "message_id": { "anyOf": [{ "$ref": "#/$defs/Uuid" }, { "type": "null" }] },
                "problem": { "$ref": "#/$defs/Problem" }
              }
            }
          }
        }
      ]
    },

    "Heartbeat": {
      "allOf": [
        { "$ref": "#/$defs/EventBase" },
        {
          "type": "object",
          "required": ["data"],
          "properties": {
            "event": { "const": "heartbeat" },
            "data": {
              "type": "object",
              "required": ["at"],
              "properties": {
                "at": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      ]
    }
  }
}
